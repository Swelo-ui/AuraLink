# ─── Supabase Configuration ───────────────────────────────────────────────────
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key-here"

# ─── Telegram Bot (File Storage Backend) ──────────────────────────────────────
VITE_TG_BOT_TOKEN="your-telegram-bot-token"
VITE_TG_CHAT_ID="your-telegram-chat-id"

# ─── Push Notifications (VAPID Keys) ─────────────────────────────────────────
VITE_VAPID_PUBLIC_KEY="your-vapid-public-key"

# ─── AI/LLM (Server-side only, used by Edge Functions) ───────────────────────
# These should NOT be prefixed with VITE_ as they should not be in the client bundle
GEMINI_API_KEY="your-gemini-api-key"
NVIDIA_API_KEY="your-nvidia-api-key"
